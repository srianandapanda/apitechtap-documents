# Copy to .env in this folder:  cp .env.example .env
# Used by docker compose and scripts under ../scripts/

# --- Published host ports (avoid clashes when all stacks run together) ---
AUTH_HOST_PORT=8081
USER_MANAGEMENT_HOST_PORT=8082
ASSIST_HOST_PORT=8083
PLAN_PAYMENT_HOST_PORT=8084
POSTGRES_HOST_PORT=5435
MONGO_HOST_PORT=27018

# --- Shared auth JWT signing (must match across auth, ums, assist, plan-payment) ---
JWT_SECRET=change-this-secret-key-change-this-secret-key

# --- user-management internal HTTP Basic (assist + plan-payment call /internal/v1/...) ---
USER_MANAGEMENT_INTERNAL_USERNAME=internal
USER_MANAGEMENT_INTERNAL_PASSWORD=changeme-internal

# --- plan-payment -> user-management PATCH /core (same credentials as internal API user) ---
INTERNAL_PAYMENT_TO_PROFILE_USER=internal
INTERNAL_PAYMENT_TO_PROFILE_PASSWORD=changeme-internal

# --- plan-payment: set false in Docker so user rows get currentPlanId updates ---
PLANPAYMENT_USER_MANAGEMENT_MOCK=false

# --- Optional: Gradle inside Docker cannot reach Maven Central (firewall / proxy) ---
# Set these to your corporate proxy, then rebuild. Leave unset on a normal home network.
# HTTP_PROXY=http://host.docker.internal:8888
# HTTPS_PROXY=http://host.docker.internal:8888
# NO_PROXY=localhost,127.0.0.1,postgres,mongo,.internal
